    "language",
    "locale",
    "translation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artempronin/emdash-plugin-i18n-manager.git"
  },
  "peerDependencies": {
    "astro": ">=6.0.0",
    "emdash": ">=0.1.0",
    "react": "^18.0.0 || ^19.0.0"
